# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env a GitHub — está en .gitignore.

# Bot de Telegram
# Obtener token hablando con @BotFather en Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Proveedor de Gemma 4
# Cambiar GEMMA_PROVEEDOR para alternar entre desarrollo y producción:
#   "huggingface" → pruebas y desarrollo (requiere HUGGINGFACE_TOKEN)
#   "ollama"      → despliegue final en red local (servidor en 192.168.0.135)
GEMMA_PROVEEDOR=huggingface

# HuggingFace Inference API (desarrollo)
# Obtener token en: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# Ollama en red local (producción)
# Servidor Ollama corriendo en la red local con Gemma 4 cargado
OLLAMA_URL=http://192.168.0.135:11434
